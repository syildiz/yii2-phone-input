{
    "name": "syildiz/yii2-phone-input",
    "description": "Yii2 International telephone numbers - Asset Bundle, Behavior, Validator, Widget",
    "keywords": [
        "yii2",
        "intl-tel-input",
        "international telephone numbers",
        "libphonenumber"
    ],
    "minimum-stability": "dev",
    "license": "BSD-3-Clause",
    "type": "yii2-extension",
    "homepage": "https://github.com/syildiz/yii2-phone-input",
    "support": {
        "issues": "https://github.com/syildiz/yii2-phone-input/issues?state=open",
        "source": "https://github.com/syildiz/yii2-phone-input"
    },
    "authors": [{
        "name": "Sinan Yildiz",
        "email": "sinan@doktor365.com.tr"
    }],
    "autoload": {
        "psr-4": {
            "syildiz\\extensions\\phoneInput\\": "src/"
        }
    },
    "repositories": [{
        "type": "composer",
        "url": "https://asset-packagist.org"
    }],
    "require": {
        "giggsey/libphonenumber-for-php": "^8",
        "yiisoft/yii2": ">=2.0.1",
        "bower-asset/intl-tel-input": "25.2.1"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    }
}
